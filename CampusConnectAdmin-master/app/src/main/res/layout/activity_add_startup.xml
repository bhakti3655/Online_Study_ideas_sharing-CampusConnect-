<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF7F2"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#000000" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="SUBMIT NEW IDEA"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="IDEA TITLE"
                android:textColor="#C7C7CC"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etIdeaTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@android:drawable/ic_menu_edit"
                android:drawablePadding="12dp"
                android:hint="E.g. Campus Food Delivery"
                android:paddingStart="16dp"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="16dp"
                android:text="DOMAIN / CATEGORY"
                android:textColor="#C7C7CC"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etIdeaCategory"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="12dp"
                android:hint="E.g. Campus Services"
                android:paddingStart="16dp"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="16dp"
                android:text="BY STUDENT / TEAM"
                android:textColor="#C7C7CC"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etIdeaStudent"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@drawable/ic_user"
                android:drawablePadding="12dp"
                android:hint="E.g. Amit Patel"
                android:paddingStart="16dp"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="16dp"
                android:text="DESCRIPTION"
                android:textColor="#C7C7CC"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etIdeaDescription"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:padding="16dp"
                android:inputType="textMultiLine" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSubmitIdea"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/primaryRed"
        android:text="SUBMIT IDEA NOW"
        android:textStyle="bold"
        app:cornerRadius="28dp" />

</LinearLayout>